# ═══════════════════════════════════════════════════════════════════════════════
# OnixFrame – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
# Paste your NeonDB connection string here (from neon.tech dashboard → Connection string → Pooler):
DATABASE_URL="postgresql://<user>:<password>@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123          # min 8 characters
MINIO_BUCKET=onixframe-videos

# Public-facing URL for presigned video links (what browsers use):
# Local:  http://localhost:9000
# EC2:    http://<YOUR_EC2_PUBLIC_IP>:9000
MINIO_PUBLIC_URL=http://localhost:9000
NEXT_PUBLIC_MINIO_URL=http://localhost:9000

# ── Whisper Model Size ────────────────────────────────────────────────────────
# tiny | base | small | medium | large
# base = good balance of speed and accuracy (~1 GB RAM)
# small = better accuracy (~2 GB RAM)
WHISPER_MODEL_SIZE=base

# ── Ollama LLM ────────────────────────────────────────────────────────────────
OLLAMA_MODEL=llama3.2:3b

# ── App URLs ──────────────────────────────────────────────────────────────────
# Local:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# EC2:
# NEXT_PUBLIC_APP_URL=http://<EC2_PUBLIC_IP>:3000

# EC2 public IP for Next.js Image remotePatterns (leave empty locally):
EC2_PUBLIC_IP=
